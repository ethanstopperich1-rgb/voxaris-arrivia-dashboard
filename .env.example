# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_API_KEY=replace_me
DASHBOARD_BASIC_AUTH_USER=admin
DASHBOARD_BASIC_AUTH_PASS=replace_me

# Retell
RETELL_API_KEY=replace_me
RETELL_AGENT_ID=replace_me
RETELL_LLM_ID=replace_me
RETELL_PHONE_NUMBER=+10000000000
RETELL_WEBHOOK_SECRET=replace_me
RETELL_OUTAGE_FALLBACK_NUMBER=+10000000000
RETELL_LLM_WEBSOCKET_URL=wss://your-ws-server.example.com/retell/custom-llm-ws?token=replace_me
RETELL_LLM_WEBSOCKET_SECRET=replace_me

# Twilio
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=+10000000000
TWILIO_GVR_DEMO_DID=+10000000000
TWILIO_SIP_TRUNK_SID=replace_me
TWILIO_TERMINATION_SIP_URI=replace_me.pstn.twilio.com

# LLMs
ANTHROPIC_API_KEY=replace_me
OPENAI_API_KEY=replace_me
COHERE_API_KEY=replace_me

# Helicone
HELICONE_API_KEY=replace_me
HELICONE_BASE_URL=https://oai.helicone.ai

# Supabase
NEXT_PUBLIC_SUPABASE_URL=replace_me
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_DB_URL=replace_me

# Redis / Upstash
UPSTASH_REDIS_REST_URL=replace_me
UPSTASH_REDIS_REST_TOKEN=replace_me

# Specialist transfer
PRIMARY_SPECIALIST_NUMBER=+10000000000
BACKUP_SPECIALIST_NUMBER=+10000000000
PRIMARY_SPECIALIST_SIP_URI=
SPECIALIST_SMS_NUMBER=+10000000000
SPECIALIST_EMAIL=ops@example.com
SPECIALIST_SCREEN_POP_BASE_URL=https://gvr-voice.voxaris.ai/transfer

# Demo controls
DEMO_MODE=true
ANSWER_CARD_ONLY_MODE=false
ALLOW_FULL_RAG=true
ENABLE_VERIFICATION_PASS=true
ENABLE_PRICING_VALIDATOR=true
ENABLE_RETELL_NATIVE_KB=false
TRANSFER_TIMEOUT_SECONDS=10
MAX_RESPONSE_LATENCY_MS=800
FULL_RAG_FILLER_THRESHOLD_MS=700
KILL_SWITCH=false
